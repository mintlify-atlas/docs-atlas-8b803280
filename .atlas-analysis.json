  "keyFeatures": [
    "MinHash-based code similarity detection for disassembled binaries",
    "REST API server with asynchronous job queue processing",
    "PicHash and PicBlockHash for position-independent code matching",
    "Extensible shingler system for customizable function encoding",
    "IDA Pro plugin for interactive reverse engineering workflow",
    "Python client library for programmatic access",
    "CLI tool for batch processing and automation",
    "MongoDB-backed persistent storage with configurable backends",
    "Cross-matching and family-based sample organization",
    "Unique block identification for signature generation"
  ],
  "publicApiSurface": [
    "mcrit server - Start REST API server",
    "mcrit worker - Start job processing worker",
    "mcrit spawningworker - Start worker with subprocess isolation",
    "mcrit client - Launch interactive CLI client",
    "McritClient - Python client class for API access",
    "POST /samples/binary - Submit binary sample",
    "GET /matches/sample/{sample_id} - Get sample matches",
    "POST /query/binary - Query binary for matches",
    "GET /families - List malware families",
    "GET /jobs - List processing jobs",
    "GET /status - Get system status",
    "POST /query/pichash/{pichash} - Query by PicHash",
    "GET /uniqueblocks/samples/{sample_ids} - Get unique blocks",
    "POST /export - Export samples",
    "POST /import - Import samples"
  ]
